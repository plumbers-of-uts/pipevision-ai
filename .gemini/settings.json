{
  "hooks": {
    "BeforeAgent": [
      {
        "hooks": [
          {
            "name": "keyword-detector",
            "type": "command",
            "command": "bun \"$GEMINI_PROJECT_DIR/.gemini/hooks/keyword-detector.ts\"",
            "timeout": 5000
          },
          {
            "name": "skill-injector",
            "type": "command",
            "command": "bun \"$GEMINI_PROJECT_DIR/.gemini/hooks/skill-injector.ts\"",
            "timeout": 3000
          }
        ],
        "matcher": "*"
      }
    ],
    "BeforeTool": [
      {
        "hooks": [
          {
            "name": "test-filter",
            "type": "command",
            "command": "bun \"$GEMINI_PROJECT_DIR/.gemini/hooks/test-filter.ts\"",
            "timeout": 5000
          }
        ],
        "matcher": "run_shell_command"
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "name": "persistent-mode",
            "type": "command",
            "command": "bun \"$GEMINI_PROJECT_DIR/.gemini/hooks/persistent-mode.ts\"",
            "timeout": 5000
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "general": {
    "enableNotifications": true
  },
  "experimental": {
    "enableAgents": true
  },
  "mcpServers": {
    "serena": {
      "command": "serena",
      "args": [
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "."
      ],
      "env": {
        "SERENA_LOG_LEVEL": "info"
      }
    }
  },
  "privacy": {
    "usageStatisticsEnabled": false
  }
}
