# FlowBust — Environment Variables
# Copy this file to .env.local and fill in real values before running.
# NEVER commit .env.local to version control.

# ── Required: Model URL (HF Hub ONNX file)
# Format: https://huggingface.co/<user>/<repo>/resolve/main/<file>.onnx
# Default points at the unified yolo26m-seg model that emits bbox + mask.
VITE_MODEL_URL=https://huggingface.co/gracefullight/pipevision-yolo26m-seg/resolve/main/yolo26m-seg-fp16.onnx

# ── Required: SHA-256 fingerprint of the ONNX file (64 hex chars)
# Obtain with: sha256sum yolo26m-seg-fp16.onnx | awk '{print $1}'
# Published in model/metadata.yaml after the training run.
# Leave blank during local development to skip integrity check (a warning is logged).
VITE_MODEL_SHA256=315d02d175883534892e0b19de55dc7730e0bcc197877eca969347abfb42420e

# ── Required: model task — "segment" (default) or "detect"
# "segment" expects a dual-output ONNX (detections + prototypes) and renders
# instance masks. "detect" is the legacy bbox-only mode.
VITE_MODEL_TASK=segment

# ── Optional: Hugging Face Spaces fallback URL
# When set, an error card button "Try on Hugging Face Spaces" becomes visible.
# Format: https://<hf-user>-<space-name>.hf.space
VITE_SPACES_URL=
