{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "ignore": [
      "node_modules",
      "dist",
      ".vite",
      "model",
      "src/components/ui",
      ".agents",
      ".claude",
      ".codex",
      ".cursor",
      ".gemini",
      ".qwen",
      ".serena",
      ".github",
      "docs",
      "gui-mockup.html",
      "*.md",
      "tsconfig.json",
      "tsconfig.node.json",
      "components.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "warn"
      },
      "style": {
        "useImportType": "error",
        "useConst": "error"
      },
      "a11y": {
        "noSvgWithoutTitle": "off",
        "useAltText": "error",
        "useButtonType": "error",
        "useKeyWithClickEvents": "warn",
        "useSemanticElements": "off",
        "useFocusableInteractive": "warn",
        "noLabelWithoutControl": "warn",
        "noRedundantAlt": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "include": ["*.ts", "*.tsx"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "error"
          }
        }
      }
    }
  ]
}
