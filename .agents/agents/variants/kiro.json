{
  "$schema": "./agent-variant.schema.json",
  "vendor": "kiro",
  "destDir": ".kiro/agents",
  "modelDefault": "inherit",
  "maxTurnsDefault": 20,
  "toolsDefault": [
    "read",
    "write",
    "shell",
    "grep",
    "glob",
    "code",
    "subagent"
  ],
  "protocolPath": ".agents/skills/_shared/runtime/execution-protocols/kiro.md",
  "agents": {
    "backend-engineer": {},
    "frontend-engineer": {},
    "db-engineer": {
      "maxTurns": 15
    },
    "debug-investigator": {
      "maxTurns": 15
    },
    "architecture-reviewer": {
      "tools": ["read", "grep", "glob", "code"],
      "maxTurns": 15
    },
    "tf-infra-engineer": {
      "maxTurns": 20
    },
    "mobile-engineer": {},
    "pm-planner": {
      "tools": ["read", "grep", "glob", "shell"],
      "maxTurns": 10
    },
    "qa-reviewer": {
      "tools": ["read", "grep", "glob", "shell"],
      "maxTurns": 15
    },
    "docs-curator": {
      "maxTurns": 15
    }
  }
}
