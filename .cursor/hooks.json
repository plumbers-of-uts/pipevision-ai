{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "name": "keyword-detector",
            "type": "command",
            "command": "bun .cursor/hooks/keyword-detector.ts",
            "timeout": 5
          },
          {
            "name": "state-boundary",
            "type": "command",
            "command": "bun .cursor/hooks/state-boundary.ts",
            "timeout": 5
          },
          {
            "name": "skill-injector",
            "type": "command",
            "command": "bun .cursor/hooks/skill-injector.ts",
            "timeout": 3
          }
        ]
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "'.cursor/hooks/oma-hook.sh' --vendor 'cursor' --event 'beforeSubmitPrompt'",
        "timeout": 21
      }
    ]
  },
  "version": 1
}
